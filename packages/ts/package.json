{
  "name": "harness",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "workspaces": [
    "packages/*",
    "vendors/langgraph-harness-integration",
    "vendors/langgraph-repo-remediation-html-report-generator"
  ],
  "engines": {
    "node": ">=20"
  },
  "packageManager": "npm@11.6.2",
  "scripts": {
    "test": "npm test --workspaces --if-present",
    "lint": "eslint . && biome lint .",
    "format": "prettier --write .",
    "deps:merge": "node scripts/merge-package-deps.mjs",
    "deps:check": "node scripts/merge-package-deps.mjs --check",
    "graph": "node scripts/graph-png.mjs",
    "verify": "node scripts/verify.mjs"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.3",
    "@eslint/js": "10.0.1",
    "@testing-library/react": "^14.1.2",
    "@types/node": "22.20.1",
    "@types/react": "^18.2.45",
    "@types/react-dom": "^18.2.18",
    "@vitejs/plugin-react": "6.0.3",
    "ajv": "8.17.1",
    "ajv-formats": "3.0.1",
    "autoprefixer": "^10.4.16",
    "eslint": "10.6.0",
    "jsdom": "^24.0.0",
    "postcss": "^8.4.32",
    "prettier": "3.9.4",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^7.1.5",
    "tailwindcss": "^3.4.0",
    "tsx": "4.19.1",
    "typescript": "5.9.2",
    "vite": "8.0.16",
    "vitest": "^1.3.1"
  },
  "dependencies": {
    "@clack/core": "1.4.3",
    "@clack/prompts": "1.7.0",
    "@iarna/toml": "2.2.5",
    "@langchain/core": "1.1.48",
    "@langchain/langgraph": "1.3.4",
    "chalk": "5.6.2",
    "commander": "15.0.0",
    "csv-parse": "7.0.1",
    "dependency-tree": "^12.0.1",
    "exceljs": "4.4.0",
    "fast-xml-parser": "4.5.0",
    "fastify": "5.8.5",
    "knip": "^6.25.0",
    "yaml": "2.9.0",
    "zod": "3.25.76"
  }
}
